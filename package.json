{
    "name": "obsidian-ghostty-terminal",
    "version": "0.1.1",
    "description": "Ghostty Terminal for Obsidian",
    "main": "main.js",
    "scripts": {
        "dev": "node esbuild.config.mjs",
        "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
        "version": "node version-bump.mjs && git add manifest.json versions.json"
    },
    "dependencies": {
        "ghostty-web": "^0.4.0",
        "node-pty": "^1.1.0",
        "node-pty-prebuilt-multiarch": "^0.10.1-pre.5"
    },
    "devDependencies": {
        "@types/node": "^20",
        "builtin-modules": "^5.0.0",
        "esbuild": "0.21.5",
        "obsidian": "latest",
        "tslib": "2.6.2",
        "typescript": "5.5.4"
    }
}